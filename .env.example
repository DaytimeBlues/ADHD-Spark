# ============================================================================
# Environment Variables - ADHD-CADDI
# ============================================================================
# Copy this file to .env for local development.
#
# IMPORTANT:
# - Variables prefixed with EXPO_PUBLIC_ are bundled into the client.
# - Treat EXPO_PUBLIC_ values as public values, not secrets.
# - Real secrets belong in server-side env vars or CI secrets.
# ============================================================================

# client-public, optional
# Sets the runtime label used in logs and config diagnostics.
# EXPO_PUBLIC_ENV=development

# client-public, optional
# Public API base URL used by the web and native clients.
# EXPO_PUBLIC_API_BASE_URL=https://spark-adhd-api.vercel.app

# client-public, optional
# Google OAuth client IDs are public identifiers, not secrets.
# If both are unset, Google sync features stay disabled but the app still boots.
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

# client-public, optional
# Sentry DSN is safe to expose because it is an ingest key, not an admin secret.
# EXPO_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# client-public, optional
# Keep production on the server-backed provider unless you are debugging locally.
# EXPO_PUBLIC_AI_PROVIDER=vercel
# EXPO_PUBLIC_AI_TIMEOUT=8000
# EXPO_PUBLIC_AI_MAX_RETRIES=3
# EXPO_PUBLIC_KIMI_MODEL=kimi-k2.5

# client-public, optional
# Development-only escape hatch for direct client AI calls.
# This still exposes the key to end users, so do not use it for real production secrets.
# EXPO_PUBLIC_ENABLE_INSECURE_DIRECT_AI=false
# EXPO_PUBLIC_GEMINI_API_KEY=
# EXPO_PUBLIC_MOONSHOT_API_KEY=

# server-only, optional
# These are examples of values that must NOT go in the client app env.
# Put them in the backend or CI environment instead.
# GEMINI_API_KEY=
# MOONSHOT_API_KEY=
# SENTRY_AUTH_TOKEN=
