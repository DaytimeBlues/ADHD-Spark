    "review::.::holistic::initialization_coupling::storage_init_coupling::ed4f64f6": {
      "id": "review::.::holistic::initialization_coupling::storage_init_coupling::ed4f64f6",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "Eager database initialization and module-level side effects",
      "detail": {
        "holistic": true,
        "dimension": "initialization_coupling",
        "related_files": [
          "src/services/StorageService.ts"
        ],
        "evidence": [
          "StorageService eager-loads sqlite via 'require' and initializes the 'db' variable at module scope, which makes server-side rendering or testing without mocks fragile."
        ],
        "suggestion": "Move database opening logic into the 'init' function or use a lazy getter.",
        "reasoning": ""
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-01T07:46:13+00:00",
      "last_seen": "2026-03-01T07:46:13+00:00",
