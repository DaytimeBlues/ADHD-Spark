      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "Import cycle between CaptureService and useCaptureStore",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "src/services/CaptureService.ts",
          "src/store/useCaptureStore.ts"
        ],
        "evidence": [
          "A mutual dependency existence between the state persistence layer and the business logic service."
        ],
        "suggestion": "Refactor CaptureService to be a pure middleware or move common types to a shared location to break the cycle.",
