{
  "name": "adhd-caddi-rn",
  "version": "1.0.0",
  "private": true,
  "homepage": "https://daytimeblues.github.io/ADHD-CADDI/",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "web": "webpack serve --mode development",
    "build:web": "webpack --mode production",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "jest",
    "prepare": "husky",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:regression": "./scripts/regression.sh",
    "e2e": "playwright test",
    "e2e:smoke": "playwright test e2e/smoke-basic.spec.ts --project=chromium",
    "e2e:core": "playwright test e2e/tutorial-bubble-smoke.spec.ts e2e/bubble-features.spec.ts --project=chromium",
    "e2e:ui": "playwright test --ui",
    "test:e2e:android": "detox test -c android.debug",
    "build:android": "cd android && gradlew.bat assembleDebug",
    "build:android:dev": "cd android && gradlew.bat assembleDebug",
    "build:android:preview": "cd android && gradlew.bat assemblePreview",
    "build:android:prod": "cd android && gradlew.bat assembleRelease",
    "build:android:sideload": "node scripts/android/build-sideload-release.js",
    "android:sync-audio": "node scripts/android/sync-audio-assets.js",
    "android:check-audio": "node scripts/android/sync-audio-assets.js --check",
    "build:release": "cd android && gradlew.bat assembleRelease",
    "install:android:dev": "cd android && gradlew.bat installDebug",
    "install:android:preview": "cd android && gradlew.bat installPreview",
    "predeploy": "npm run build:web",
    "deploy": "gh-pages -d dist",
    "deploy:firebase": "npm run build:web && firebase deploy --only hosting",
    "android:dev": "react-native run-android",
    "android:clean": "cd android && gradlew.bat --stop 2>nul || true && gradlew.bat :app:clean --no-daemon",
    "admin:config-check": "node scripts/admin/check-config.js",
    "admin:storage-status": "node scripts/admin/storage-status.js",
    "admin:backup-check": "node scripts/admin/backup-check.js",
    "admin:web-health": "node scripts/admin/web-health.js",
    "admin:android-health": "node scripts/admin/android-health.js",
    "admin:check": "npm run admin:config-check && npm run admin:storage-status && npm run admin:backup-check && npm run admin:web-health && npm run admin:android-health",
    "verify": "npm run lint && npx tsc --noEmit && npm test -- --runInBand && npm run admin:check",
    "quality:report": "node scripts/quality/file-size-check.js --report-top 30"
  },
  "dependencies": {
    "@op-engineering/op-sqlite": "^14.1.4",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native-google-signin/google-signin": "^16.1.1",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/stack": "^6.3.29",
    "@sentry/react-native": "^8.1.0",
    "expo-asset": "^55.0.8",
    "expo-av": "^16.0.8",
    "expo-haptics": "^55.0.8",
    "expo-local-authentication": "^17.0.8",
    "expo-modules-core": "^55.0.13",
    "expo-notifications": "^0.32.16",
    "react": "18.2.0",
    "react-dom": "^18.2.0",
    "react-native": "0.74.3",
    "react-native-gesture-handler": "2.16.2",
    "react-native-reanimated": "3.11.0",
    "react-native-safe-area-context": "^4.10.6",
    "react-native-screens": "^3.32.0",
    "react-native-sound": "^0.11.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@babel/core": "^7.24.7",
    "@babel/preset-env": "^7.24.7",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@babel/runtime": "^7.24.7",
    "@playwright/test": "^1.58.1",
    "@react-native/babel-preset": "0.74.87",
    "@react-native/eslint-config": "0.74.87",
    "@react-native/metro-config": "0.74.87",
    "@react-native/typescript-config": "0.74.87",
    "@testing-library/react-native": "^12.5.0",
    "@types/react": "^18.2.79",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "^18.3.0",
    "babel-loader": "^10.0.0",
    "detox": "^20.24.1",
    "eslint": "^8.57.0",
    "eslint-plugin-prettier": "^5.5.5",
    "gh-pages": "^6.3.0",
    "html-webpack-plugin": "^5.6.6",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.3.1",
    "prettier": "3.3.2",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "^0.21.2",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.9.3",
    "typescript-language-server": "^5.1.3",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  },
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write",
      "jest --bail --findRelatedTests --passWithNoTests"
    ],
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write",
      "jest --bail --findRelatedTests --passWithNoTests"
    ]
  }
}
